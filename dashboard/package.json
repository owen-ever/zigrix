{
  "name": "zigrix-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --max-warnings=0",
    "format": "prettier --write \"package.json\" \"package-lock.json\" \"next.config.ts\"",
